# ═══════════════════════════════════════════════════════════
# 道 · Agent Remote Repair Hub — 环境配置
# 复制为 .env 后修改 (可选, 所有值均有合理默认)
# ═══════════════════════════════════════════════════════════

# ── 核心端口 ──
# PORT=3002                    # Hub主端口 (道核动态分配时忽略)

# ── 隧道 ──
# NO_TUNNEL=1                  # 禁用SSH公网隧道

# ── 投屏链路: 万法之资 — 适配一切协议 ──
# SCRCPY_HUB_PORT=8890         # scrcpy Hub (Android最强)
# MJPEG_PORT=8081              # MJPEG投屏 + InputRoutes
# INPUT_PORT=8084              # ScreenStream / InputRoutes
# GHOST_SHELL_PORT=8000        # ghost_shell (Windows桌面30fps)
# DAO_REMOTE_PORT=9900         # dao-remote (亲情远程Go版)
# ADB_HUB_PORT=9861            # adb_hub (ADB全控中枢)
# ADB_HUB_TOKEN=adb_hub_2026   # adb_hub认证令牌

# ── 高级 ──
# PUBLIC_URL=localhost:3002    # 公网URL (隧道建立后自动覆盖)
# RELAY_PORT=9910              # PS Agent Relay端口 (道核动态分配时忽略)
