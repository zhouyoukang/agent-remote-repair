# ═══════════════════════════════════════════════════════════
# 道 · Agent Remote Repair Hub — 环境配置
#
# 道可道 非常少. 此文件中所有变量均为"首选值覆盖", 无字面量后备:
#   · 未指定 → 从 Ed25519 身份 / 网络接口 / 端口探测涌现
#   · 指定 → 运行时尊重你的选择
# 所以这个文件完全可以为空. 0 配置即可启动.
# ═══════════════════════════════════════════════════════════

# ── 核心端口 ──
# PORT=3002                    # Hub 主端口. 冲突时 hub 自动 +1 重试至可用. 无值=3002

# ── 公网入口 (四选一或全不选) ──
# NO_TUNNEL=1                  # 禁用 cloudflared/ngrok/SSH 公网隧道
# DAO_NO_NAT=1                 # 禁用 UPnP IGD / NAT-PMP 自穿
# PUBLIC_URL=<host[:port]>     # 预置公网 URL (隧道/NAT 成功后会自动覆盖此值)

# ── 投屏链路: 万法之资 · 首选端口 (未活时 registry 会自动探测 portCandidates) ──
# SCRCPY_HUB_PORT=8890         # scrcpy Hub
# MJPEG_PORT=8081              # MJPEG
# INPUT_PORT=8084              # ScreenStream / InputRoutes
# GHOST_SHELL_PORT=8000        # ghost_shell (Windows 桌面)
# DAO_REMOTE_PORT=9900         # dao-remote Go
# ADB_HUB_PORT=9861            # adb_hub
# SUNLOGIN_PORT=13333          # 向日葵本地 API

# ── 令牌 (默认从 Ed25519 身份确定性派生, 无字面量后备) ──
# ADB_HUB_TOKEN=<自动>          # 留空=身份派生 serviceToken("adb_hub"); 仅在共享现有 adb_hub 实例时设置
# PS_AGENT_MASTER_TOKEN=<自动>  # 留空=身份签发的 7 天 Ed25519 JWT

# ── 高级 ──
# RELAY_PORT=9910              # PS Agent Relay 首选端口 (道核动态分配时忽略)
