# ============================================================
# PS Agent Relay Server Configuration
# Copy to .env and customize
# ============================================================

# Server port (default: 9910)
PS_AGENT_PORT=9910

# Master token for AI/management API access
# CHANGE THIS to a strong random string in production
PS_AGENT_MASTER_TOKEN=change-me-your-secret-token

# Public URL (how agents reach this server)
# Examples:
#   PS_AGENT_PUBLIC_URL=http://localhost:9910          # Local dev
#   PS_AGENT_PUBLIC_URL=https://yourdomain.com/ps-agent  # Behind reverse proxy
PS_AGENT_PUBLIC_URL=http://localhost:9910

# Path prefix if behind a reverse proxy (e.g., /ps-agent)
PS_AGENT_PATH_PREFIX=

# Machine aliases (JSON): friendly names -> hostnames
# Example: {"desktop":"DESKTOP-ABC","laptop":"LAPTOP-XYZ"}
PS_AGENT_ALIASES={}
