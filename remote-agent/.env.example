# Server port (default: 3002)
PORT=3002

# Public URL for the sense page (how users access the page)
# Examples:
#   PUBLIC_URL=121.40.70.212:9001    # China domestic (low latency)
#   PUBLIC_URL=us.afrp.net:53002     # US server
#   PUBLIC_URL=localhost:3002         # Local dev
PUBLIC_URL=localhost:3002
