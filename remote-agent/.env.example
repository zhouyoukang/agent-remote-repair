# Server port (default: 3002)
PORT=3002

# Public URL for the sense page (how users access the page)
# Examples:
#   PUBLIC_URL=your-server.com:3002   # Your public server
#   PUBLIC_URL=192.168.1.100:3002     # LAN IP
#   PUBLIC_URL=localhost:3002          # Local dev
PUBLIC_URL=localhost:3002

# PS Agent Relay master token (must match ps-agent server)
# PS_AGENT_MASTER_TOKEN=change-me-your-secret-token

# Public Relay URL (optional, for WAN fallback when LAN discovery fails)
# PUBLIC_RELAY=https://your-domain.com/ps-agent

# Relay port (default: 9910)
# RELAY_PORT=9910

# Known LAN IP octets for fast relay discovery (comma-separated last octets)
# Default: 1 (gateway). Add your relay machine's last octet for faster discovery.
# PROBE_OCTETS=1,100,200
